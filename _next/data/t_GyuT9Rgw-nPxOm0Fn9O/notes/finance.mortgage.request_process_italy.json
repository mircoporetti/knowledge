{"pageProps":{"note":{"id":"finance.mortgage.request_process_italy","title":"Mortgage Request Process in Italy","desc":"","updated":1712332800000,"created":1712332800000,"custom":{},"fname":"finance.mortgage.request_process_italy","type":"note","vault":{"fsPath":"vault"},"contentHash":"5d3eb1ec216e5ca433e53c79892ce13b","links":[],"anchors":{"steps":{"type":"header","text":"Steps","value":"steps","line":8,"column":0,"depth":2}},"children":[],"parent":"finance.mortgage","data":{}},"body":"<h1 id=\"mortgage-request-process-in-italy\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#mortgage-request-process-in-italy\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Mortgage Request Process in Italy</h1>\n<h2 id=\"steps\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#steps\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Steps</h2>\n<ol>\n<li>\n<p><strong>Shop around for the best offer</strong> - Visit multiple banks to compare offers vs. relying on a broker</p>\n</li>\n<li>\n<p><strong>Include a clausola sospensiva in the purchase proposal</strong> - When making the purchase proposal at the real estate agency, include a <em>clausola sospensiva</em> (suspensive clause) that clearly specifies:</p>\n<ul>\n<li>The mortgage amount</li>\n<li>What the clause is tied to (income approval - <em>delibera reddituale</em> - or actual mortgage obtainment)</li>\n</ul>\n</li>\n<li>\n<p><strong>Request official confirmation</strong> - Ask for official confirmation that the mortgage application has been submitted</p>\n</li>\n<li>\n<p><strong>Istruttoria (preliminary assessment)</strong> - The bank evaluates whether you qualify for the mortgage and what monthly payment you can afford. Factors considered:</p>\n<ul>\n<li>Salary and employment type (employee vs. <em>partita IVA</em> / self-employed)</li>\n<li>Cost of living in the area</li>\n<li>The mortgage payment cannot exceed the subsistence threshold based on the area</li>\n<li>Number of dependents</li>\n<li>Credit history (any unpaid installments or other issues?)</li>\n<li>Other ongoing loans or financing</li>\n</ul>\n</li>\n<li>\n<p><strong>Perizia (property appraisal)</strong> - The bank's technical expert appraises the property. If the property value is estimated lower than the purchase price, the bank may grant a smaller mortgage</p>\n</li>\n<li>\n<p><strong>Atto di mutuo (mortgage deed)</strong> - Final signing of the mortgage deed before the notary</p>\n</li>\n</ol>","noteIndex":{"id":"wn8PE1RhG0znK1alrGFYv","title":"Knowledge","desc":"","updated":1653052058421,"created":1631901573363,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"b500019acb88c6ee12fd13841e186668","links":[],"anchors":{},"children":["finance","427tmwxym406ososu8y3vl8","qlyp13dhorqnejqy9t6koun","vha3f8oqcnooj9rrefcz88i","bh5rjgdtm932h5b4u3lsp0g"],"parent":null,"data":{},"body":"\n"},"collectionChildren":null,"customHeadContent":"<style>\n/* Fix for anchor heading SVG taking up too much space */\n.anchor-heading {\n  display: inline !important;\n}\n\n.anchor-heading svg {\n  display: inline !important;\n  width: 1em !important;\n  height: 1em !important;\n  vertical-align: middle !important;\n}\n</style>\n","config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":false,"leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2,"vaultSelectionModeOnCreate":"smart"}},"insertNote":{"initialValue":"templates"},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"randomNote":{},"copyNoteLink":{"aliasMode":"title"},"templateHierarchy":"template"},"workspace":{"vaults":[{"fsPath":"vault"}],"journal":{"dailyDomain":"daily","name":"journal","dateFormat":"y.MM.dd","addBehavior":"childOfDomain"},"scratch":{"name":"scratch","dateFor